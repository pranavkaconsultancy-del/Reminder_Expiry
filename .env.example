# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# RESEND_API_KEY: Required to send notification emails through Resend API.
# Add your real Resend API key here or configure it in the Secrets panel in the AI Studio UI.
RESEND_API_KEY=""

# SUPABASE_DATABASE_URL: Your Supabase transaction or session pooler PostgreSQL connection string
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
SUPABASE_DATABASE_URL=""

# SUPABASE_URL: Your Supabase Project URL (e.g. https://xxxxxx.supabase.co)
SUPABASE_URL=""

# SUPABASE_ANON_KEY: Your Supabase Anon/Public API Key
SUPABASE_ANON_KEY=""


